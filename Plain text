<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Hosea Digital Hub</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#0f172a;
    color:white;
}

header{
    background:#020617;
    padding:20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
}

.logo{
    font-size:28px;
    color:#00ff99;
    font-weight:bold;
}

nav a{
    color:white;
    text-decoration:none;
    margin:10px;
    font-size:18px;
}

.hero{
    min-height:90vh;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
    background:linear-gradient(to right,#0f172a,#111827);
}

.hero-content h1{
    font-size:55px;
    margin-bottom:20px;
}

.hero-content span{
    color:#00ff99;
}

.hero-content p{
    font-size:20px;
    color:#cbd5e1;
    margin-bottom:30px;
}

.btn{
    padding:15px 35px;
    background:#00ff99;
    color:black;
    text-decoration:none;
    border-radius:12px;
    font-weight:bold;
    transition:0.3s;
}

.btn:hover{
    background:white;
}

.section{
    padding:80px 20px;
    text-align:center;
}

.section h2{
    font-size:40px;
    margin-bottom:20px;
}

.services{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
    margin-top:40px;
}

.service-box{
    background:#1e293b;
    padding:30px;
    border-radius:15px;
    transition:0.3s;
}

.service-box:hover{
    transform:translateY(-10px);
}

.service-box h3{
    color:#00ff99;
    margin-bottom:15px;
}

.contact{
    background:#111827;
    padding:60px 20px;
    text-align:center;
}

input, textarea{
    width:100%;
    max-width:500px;
    margin:10px auto;
    padding:15px;
    border:none;
    border-radius:10px;
    display:block;
}

button{
    padding:15px 30px;
    background:#00ff99;
    border:none;
    border-radius:10px;
    cursor:pointer;
    font-size:18px;
    font-weight:bold;
}

footer{
    text-align:center;
    padding:20px;
    background:#020617;
    color:#94a3b8;
}

</style>
</head>

<body>

<header>

<div class="logo">Hosea Hub</div>

<nav>
<a href="#">Home</a>
<a href="#">Services</a>
<a href="#">About</a>
<a href="#">Contact</a>
</nav>

</header>

<section class="hero">

<div class="hero-content">

<h1>Build Your <span>Digital Future</span></h1>

<p>
Modern websites, content creation and online solutions.
</p>

<a href="#" class="btn">Start Now</a>

</div>

</section>

<section class="section">

<h2>What I Do</h2>

<div class="services">

<div class="service-box">
<h3>Website Design</h3>
<p>
Responsive websites for business, portfolio and online stores.
</p>
</div>

<div class="service-box">
<h3>TikTok Content</h3>
<p>
AI videos, scripts and trending content ideas.
</p>
</div>

<div class="service-box">
<h3>Online Support</h3>
<p>
Help with GitHub, coding and digital projects.
</p>
</div>

</div>

</section>

<section class="contact">

<h2>Contact Me</h2>

<input type="text" placeholder="Your Name">

<input type="email" placeholder="Your Email">

<textarea rows="5" placeholder="Your Message"></textarea>

<button onclick="sendMessage()">Send Message</button>

</section>

<footer>
© 2026 Hosea Hub | Powered by GitHub Pages
</footer>

<script>

function sendMessage(){
    alert("Message Sent Successfully!");
}

</script>

</body>
</html>
